<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<AssemblyName>ListFolders</AssemblyName>
		<RootNamespace>DoenaSoft.ListFolders</RootNamespace>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<Platforms>x64</Platforms>
		<Configurations>Debug</Configurations>
		<ApplicationIcon>djdsoft.ico</ApplicationIcon>
		<ImplicitUsings>true</ImplicitUsings>
		<Version>$([System.DateTime]::Now.ToString("yyyy.MM.dd.HHmm"))</Version>
		<FileVersion>$([System.DateTime]::Now.ToString("yyyy.MM.dd.HHmm"))</FileVersion>
	</PropertyGroup>

	<ItemGroup>
	  <PackageReference Include="DoenaSoft.AbstractionLayer.IO" Version="3.0.1" />
	  <PackageReference Include="DoenaSoft.ToolBox" Version="3.0.1" />
	</ItemGroup>

	<ItemGroup>
		<Compile Update="RootItem.NotGenerated.cs">
			<DependentUpon>RootItem.xsd</DependentUpon>
		</Compile>
	</ItemGroup>

</Project>